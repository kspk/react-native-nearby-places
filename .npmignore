# npm respects `.gitignore` only when no `files` field is set; once
# `files` is in package.json, build artifacts under whitelisted dirs
# still get included. This .npmignore explicitly excludes them so we
# don't ship gradle/Xcode build output to consumers.

# Android Gradle build output
android/build/
android/.gradle/
android/local.properties
android/captures/

# iOS build output
ios/build/
ios/Pods/
ios/Podfile.lock

# Node / project tooling
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editors
.DS_Store
.idea/
.vscode/
*.iml
*.swp

# TypeScript build artifacts (we ship src/ directly per package.json `main`)
dist/
lib/
*.tsbuildinfo

# Source-only files that don't belong in the published tarball
.github/
*.log
