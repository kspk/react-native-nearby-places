{
  "name": "react-native-nearby-places",
  "version": "0.4.3",
  "description": "Native nearby Point-of-Interest search for React Native — MKLocalSearch on iOS (no key), Google Places API (New) on Android. New-architecture TurboModule, zero Expo deps.",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "ios",
    "android/src",
    "android/build.gradle",
    "react-native-nearby-places.podspec",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "mapkit",
    "mklocalsearch",
    "google-places",
    "places-api",
    "poi",
    "points-of-interest",
    "nearby",
    "places",
    "geocoding",
    "turbomodule",
    "new-architecture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kspk/react-native-nearby-places.git"
  },
  "bugs": {
    "url": "https://github.com/kspk/react-native-nearby-places/issues"
  },
  "author": "Abhishek Kumar <abhishek.karak@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/kspk/react-native-nearby-places#readme",
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "typescript": "~5.3.0"
  },
  "codegenConfig": {
    "name": "ReactNativeNearbyPlacesSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.reactnativenearbyplaces"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
